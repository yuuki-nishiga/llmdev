   "source": [
    "# 各教科の点数を変数として定義\n",
    "japanese = 85 # 国語\n",
    "math = 90 # 数学\n",
    "english = 75 # 英語\n",
    "\n",
    "# 平均点を計算\n",
    "average = (japanese + math + english) / 3\n",
    "\n",
    "# 結果を出力\n",
    "print(\"3科目の平均点は、\", average, \"点です\")"
   ]
  }
