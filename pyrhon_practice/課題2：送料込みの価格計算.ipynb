   ],
   "source": [
    "noTax = int(input(\"税抜き価格を入力してください\"))\n",
    "print(f\"税抜き価格を入力してください：{noTax}\")\n",
    "noTax *= 1.1\n",
    "\n",
    "if noTax < 2000:\n",
    "    postage = 350\n",
    "    print(f\"送料は350円です\\n送料込税込価格は{int(noTax+postage)}です。\")\n",
    "else:\n",
    "    print(f\"送料は無料です\\n送料込税込価格は{int(noTax)}です。\")"
   ]
  },
